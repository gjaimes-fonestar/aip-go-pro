{
  "name": "aip-go-pro",
  "version": "0.1.0",
  "description": "AIP Go Pro – Professional Management UI",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "daemon:build": "cmake --build ../aip-go-services/build --target aip-daemon",
    "daemon:copy:linux": "mkdir -p resources/bin/linux && cp ../aip-go-services/build/bin/aip-daemon resources/bin/linux/aip-daemon && chmod +x resources/bin/linux/aip-daemon",
    "daemon:copy:win":   "mkdir -p resources/bin/windows && cp ../aip-go-services/build/bin/aip-daemon.exe resources/bin/windows/aip-daemon.exe",
    "daemon:install:linux": "npm run daemon:build && npm run daemon:copy:linux",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package": "npm run build && electron-builder --win --linux"
  },
  "dependencies": {
    "aip-client": "file:../aip-go-services/aip-client",
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.0"
  }
}
